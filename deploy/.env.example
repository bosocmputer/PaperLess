# PaperLess production deploy env — copy to deploy/.env and fill in.
# deploy/.env is gitignored; never commit real secrets.

# Postgres
POSTGRES_DB=paperless
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=54320

# MinIO (object storage)
MINIO_ROOT_USER=paperless-minio
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
MINIO_BUCKET=paperless
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# API
API_PORT=8080
JWT_SECRET=change-me-long-random-jwt-secret
DB_STATEMENT_TIMEOUT_MS=5000

# Web
WEB_PORT=3070

# SML (disabled for pilot; set when Q1–Q4 answers land)
SML_API_BASE_URL=http://sml-api-bybos-sml-api-1:8200
