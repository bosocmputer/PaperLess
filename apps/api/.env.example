# paperless-api — copy to .env and fill. NEVER commit the real .env.

APP_HOST=0.0.0.0
APP_PORT=8080

# PaperLess database (NOT SML). PaperLess owns this DB.
DATABASE_URL=postgres://postgres:paperless@localhost:5432/paperless?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2

# Auth
JWT_SECRET=

# Object storage (MinIO)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=paperless
MINIO_USE_SSL=false

# SML access — ONLY via sml-api-bybos gateway. PaperLess never connects to SML DB.
SML_API_BASE_URL=http://192.168.2.109:8200
SML_API_KEY=
SML_TENANT=
